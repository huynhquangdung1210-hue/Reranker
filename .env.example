# Environment variables for Web Search + Reranker
# Get your API keys from the respective providers

# Search Providers
SEARCH_PROVIDER=searxng
SERPER_API_KEY=your-serper-api-key-here
SERPER_BASE_URL=https://google.serper.dev/search

SEARXNG_INSTANCE_URL=http://localhost:8080
# SEARXNG_API_KEY= optional

# Scraper Provider
SCRAPER_TYPE=crawl4ai

MAX_SEARCH_RESULTS=12

# Reranker Providers
RERANKER_TYPE=flashrank
# REGOLO_ENDPOINT =  https://api.regolo.ai/v1/rerank. Checked with Sher, curr down.
# Checked by going into regolo, logging in-> model_hub ->
BGE_RERANKER_API_URL=http://localhost:4000/rerank
BGE_RERANKER_API_KEY=your-bge-reranker-api-key-here
BGE_RERANKER_MODEL=hosted-bge-reranker-v2-m3
QWEN_RERANKER_API_URL=https://api.regolo.ai/v1/rerank ## switched to Regolo hosted
QWEN_RERANKER_API_KEY=your-qwen-reranker-api-key-here
QWEN_RERANKER_MODEL=Qwen3-Reranker-4B
JINA_API_KEY=your-jina-api-key-here
JINA_API_URL=https://api.jina.ai/v1/rerank
COHERE_API_KEY=your-cohere-api-key-here

# Two-stage reranker
TWO_STAGE_FIRST=embedding
TWO_STAGE_SECOND=qwen
TWO_STAGE_EMBEDDING_TOPK=40

# FIRECRAWL (Shared Server)
FIRECRAWL_API_KEY=your-firecrawl-api-key-here
FIRECRAWL_ENDPOINT=http://46.225.130.163:3002/v1/scrape

# CRAWL4AI
CRAWL4AI_API_URL=http://localhost:11235
# CRAWL4AI_API_KEY= optional

# FLASHRANK
FLASHRANK_API_URL=http://localhost:7996/rerank
# FLASHRANK_API_KEY= optional
FLASHRANK_MODEL=ms-marco-MultiBERT-L-12

# LITELLM for evaluation
LITELLM_API_KEY=your-litellm-api-key-here